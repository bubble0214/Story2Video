# =============================================================
# Story2Video 配置文件
# 复制为 .env 后修改：
#   cp .env.example .env
# 注意：首次启动需要初始化数据库：
#   docker compose exec postgres psql -U story2video -f scripts/init.sql
# =============================================================

# App
APP_NAME=Story2Video
APP_VERSION=1.0.0
DEBUG=true

# PostgreSQL（宿主机连接用 localhost:5434）
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_DB=story2video
POSTGRES_USER=story2video
# 修改这里后需同步修改下方的 POSTGRES_PASSWORD（docker 变量）
POSTGRES_PASSWORD=REPLACE_WITH_YOUR_OWN_PASSWORD_12345

# JWT
JWT_SECRET_KEY=REPLACE_WITH_YOUR_OWN_JWT_SECRET_32CHARS_
JWT_ALGORITHM=HS256
JWT_ISSUER=story2video
JWT_AUDIENCE=story2video-web
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption (AES-256 — must be 64 hex chars = 32 bytes)
ENCRYPTION_KEY=1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef

# Embedding (openai, deepseek, qwen)
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=

# LLM
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:3004"]

# Celery（使用 Redis 作为 broker）
CELERY_BROKER_URL=redis://localhost:6383/1
CELERY_RESULT_BACKEND=redis://localhost:6383/1

# Music Generation (suno, udio, minimax)
MUSIC_PROVIDER=suno
MUSIC_API_KEY=

# Avatar / Digital Human
AVATAR_PROVIDER=heygen
AVATAR_API_KEY=

# ── Docker compose 变量 ─────────────────────────────────────
# 修改 POSTGRES_PASSWORD 后必须同步更新此处
POSTGRES_PASSWORD=REPLACE_WITH_YOUR_OWN_PASSWORD_12345

# ── 前端 API 地址 ───────────────────────────────────────────
# 本地开发模式 (run_api.py): http://localhost:8005/api
# Docker 全栈部署 (docker-compose app 服务): http://localhost:8000/api
NEXT_PUBLIC_API_BASE_URL=http://localhost:8005/api
