# App
APP_NAME=Story2Video
APP_VERSION=1.0.0
DEBUG=false

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=story2video
POSTGRES_USER=story2video
POSTGRES_PASSWORD=change_me_in_production
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# JWT
JWT_SECRET_KEY=change_me_in_production_jwt_secret_key_32chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption (AES-256 — 64 hex chars = 32 bytes)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Embedding
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=

# LLM
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Celery (task queue — uses Redis broker)
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Music Generation
MUSIC_PROVIDER=suno
MUSIC_API_KEY=

# Avatar / Digital Human
AVATAR_PROVIDER=heygen
AVATAR_API_KEY=
